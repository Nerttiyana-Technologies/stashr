@page "/secrets"
@inject StashrApi Api
@inject IJSRuntime JS

<PageTitle>KV secrets — stashr</PageTitle>

<div class="page-head" style="display:flex;justify-content:space-between;align-items:flex-end;">
    <div>
        <h1>KV secrets</h1>
        <p class="muted">Versioned key/value secrets at the <code>secret/</code> mount.</p>
    </div>
    <button class="btn btn--primary" @onclick="StartNew">New secret</button>
</div>

<div class="kv">
    <div class="card kv__list">
        <div class="card__head">
            <nav class="kv__crumbs">
                <button class="link-btn" @onclick='() => Navigate("")'>secret</button>
                @{
                    var acc = "";
                }
                @foreach (var seg in _prefix.Split('/', StringSplitOptions.RemoveEmptyEntries))
                {
                    acc += seg + "/";
                    var target = acc;
                    <span class="faint">/</span>
                    <button class="link-btn" @onclick="() => Navigate(target)">@seg</button>
                }
            </nav>
        </div>
        <div class="card__body" style="padding:var(--space-2);">
            @if (_loading)
            {
                <p class="muted" style="padding:var(--space-3);">Loading…</p>
            }
            else if (_keys.Count == 0)
            {
                <p class="muted" style="padding:var(--space-3);">No secrets here.</p>
            }
            else
            {
                @foreach (var k in _keys)
                {
                    var isFolder = k.EndsWith('/');
                    <button class="kv__item @(IsSelected(k) ? "kv__item--active" : "")"
                            @onclick="() => OnItem(k)">
                        <span class="kv__item-icon">@(isFolder ? "▸" : "•")</span>
                        @k
                    </button>
                }
            }
        </div>
    </div>

    <div class="card kv__detail">
        @if (_editing)
        {
            <div class="card__head">
                <h2>@(_isNew ? "New secret" : "Edit secret")</h2>
                <div style="display:flex;gap:var(--space-2);">
                    <button class="btn btn--sm" @onclick="CancelEdit">Cancel</button>
                    <button class="btn btn--primary btn--sm" disabled="@_busy" @onclick="Save">Save</button>
                </div>
            </div>
            <div class="card__body">
                @if (_isNew)
                {
                    <div class="field">
                        <label class="field__label">Path</label>
                        <input class="input mono" @bind="_editPath" placeholder="e.g. app/db" />
                    </div>
                }
                <label class="field__label">Data</label>
                @foreach (var row in _rows)
                {
                    <div class="kv-row">
                        <input class="input mono" @bind="row.Key" placeholder="key" />
                        <input class="input mono" @bind="row.Value" placeholder="value" />
                        <button class="btn btn--ghost btn--sm" @onclick="() => _rows.Remove(row)">✕</button>
                    </div>
                }
                <button class="btn btn--sm" style="margin-top:var(--space-2);" @onclick="() => _rows.Add(new())">Add field</button>
                @if (_error is not null)
                {
                    <div class="alert alert--danger" style="margin-top:var(--space-4);">@_error</div>
                }
            </div>
        }
        else if (_selected is null)
        {
            <div class="card__body"><div class="empty-state"><p class="muted">Select a secret to view it.</p></div></div>
        }
        else
        {
            <div class="card__head">
                <div>
                    <h2 class="mono">@_selectedPath</h2>
                    @if (_selected.Metadata is { } m)
                    {
                        <span class="faint">version @m.Version · @m.CreatedTime.ToLocalTime().ToString("g")</span>
                    }
                </div>
                <div style="display:flex;gap:var(--space-2);">
                    <button class="btn btn--sm" @onclick="StartEdit">Edit</button>
                    <button class="btn btn--danger btn--sm" @onclick="Delete">Delete</button>
                </div>
            </div>
            <div class="card__body">
                @if (_error is not null)
                {
                    <div class="alert alert--danger" style="margin-bottom:var(--space-4);">@_error</div>
                }
                <table class="table">
                    <thead><tr><th>Key</th><th>Value</th><th style="width:1%;"></th></tr></thead>
                    <tbody>
                        @foreach (var kv in _selected.Data)
                        {
                            <tr>
                                <td class="mono">@kv.Key</td>
                                <td class="mono">@(_revealed.Contains(kv.Key) ? kv.Value : "••••••••")</td>
                                <td style="white-space:nowrap;">
                                    <button class="btn btn--ghost btn--sm" @onclick="() => Toggle(kv.Key)">
                                        @(_revealed.Contains(kv.Key) ? "Hide" : "Reveal")
                                    </button>
                                    <button class="btn btn--ghost btn--sm" @onclick="() => Copy(kv.Value)">Copy</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private string _prefix = "";
    private List<string> _keys = new();
    private bool _loading = true;

    private string? _selectedPath;
    private string? _selectedKey;
    private KvReadData? _selected;
    private readonly HashSet<string> _revealed = new();

    private bool _editing;
    private bool _isNew;
    private string _editPath = "";
    private List<Row> _rows = new();

    private bool _busy;
    private string? _error;

    private sealed class Row { public string Key { get; set; } = ""; public string Value { get; set; } = ""; }

    protected override Task OnInitializedAsync() => LoadList();

    private bool IsSelected(string k) => _selectedKey == k;

    private async Task LoadList()
    {
        _loading = true;
        _error = null;
        try { _keys = (await Api.KvListAsync(_prefix)).ToList(); }
        catch (Exception ex) { _error = ex.Message; _keys = new(); }
        finally { _loading = false; }
    }

    private async Task Navigate(string prefix)
    {
        _prefix = prefix;
        _selected = null; _selectedKey = null; _selectedPath = null;
        _editing = false;
        await LoadList();
    }

    private async Task OnItem(string key)
    {
        if (key.EndsWith('/')) { await Navigate(_prefix + key); return; }
        _selectedKey = key;
        _selectedPath = _prefix + key;
        _editing = false;
        _revealed.Clear();
        _error = null;
        try { _selected = await Api.KvReadAsync(_selectedPath); }
        catch (Exception ex) { _error = ex.Message; _selected = null; }
    }

    private void Toggle(string key)
    {
        if (!_revealed.Add(key)) _revealed.Remove(key);
    }

    private void StartNew()
    {
        _isNew = true; _editing = true; _error = null;
        _editPath = _prefix;
        _rows = new() { new() };
    }

    private void StartEdit()
    {
        if (_selected is null) return;
        _isNew = false; _editing = true; _error = null;
        _rows = _selected.Data.Select(kv => new Row { Key = kv.Key, Value = kv.Value }).ToList();
        if (_rows.Count == 0) _rows.Add(new());
    }

    private void CancelEdit() { _editing = false; _error = null; }

    private async Task Save()
    {
        var path = _isNew ? _editPath.Trim() : _selectedPath!;
        if (string.IsNullOrWhiteSpace(path)) { _error = "Path is required."; return; }
        var data = _rows.Where(r => !string.IsNullOrWhiteSpace(r.Key))
                        .ToDictionary(r => r.Key.Trim(), r => r.Value);
        _busy = true; _error = null;
        try
        {
            await Api.KvWriteAsync(path, data);
            _editing = false;
            await LoadList();
            _selectedKey = path.Contains('/') ? path[(path.LastIndexOf('/') + 1)..] : path;
            _selectedPath = path;
            _selected = await Api.KvReadAsync(path);
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _busy = false; }
    }

    private async Task Delete()
    {
        if (_selectedPath is null) return;
        _error = null;
        try
        {
            await Api.KvDeleteAsync(_selectedPath);
            _selected = null; _selectedKey = null; _selectedPath = null;
            await LoadList();
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private async Task Copy(string text) => await JS.InvokeVoidAsync("stashrClipboard.copy", text);
}
