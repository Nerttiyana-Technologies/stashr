<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Pin package sources for this repo so restore is reproducible and independent of any
    machine-level NuGet config. <clear/> drops inherited sources (including local dev feeds);
    Synthetix and all other packages resolve from nuget.org (ADR-0014; the Synthetix decision).
    If you want to consume a locally-built Synthetix instead, add its source below.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
